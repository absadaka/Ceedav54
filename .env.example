# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ceeda_dev

# ─── API Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth (JWT / sessions) ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-256-bit-hex-string
SESSION_COOKIE_SECRET=change-me-too
SESSION_DURATION_DAYS=30

# ─── OAuth providers (optional) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── WhatsApp Cloud API (optional) ─────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── Stripe (optional) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email (optional, e.g. Resend / Postmark) ──────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_...
EMAIL_FROM=noreply@ceeda.io

# ─── Platform admin ────────────────────────────────────────────────────────
PLATFORM_ADMIN_EMAIL=admin@ceeda.io

# ─── Feature flags ─────────────────────────────────────────────────────────
FF_WHATSAPP_ENABLED=false
FF_ONLINE_PAYMENTS_ENABLED=false
